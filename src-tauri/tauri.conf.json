{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Mewsic",
  "version": "0.6.9",
  "identifier": "dev.xeoniii.mewsic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator3-1",
          "librsvg2"
        ]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Mewsic",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' http://localhost:1422 http://127.0.0.1:1422; img-src 'self' data: blob: http://localhost:1422 http://127.0.0.1:1422 https://*.mzstatic.com https://*.saavncdn.com https://*.ytimg.com https://*.googleusercontent.com"
    }
  }
}